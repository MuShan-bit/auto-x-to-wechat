# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auto_x_to_wechat?schema=public

# Web
NEXTAUTH_SECRET=replace-with-a-long-random-string
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true
INTERNAL_API_BASE_URL=http://localhost:3001
INTERNAL_API_SHARED_SECRET=replace-with-an-internal-shared-secret

# API
PORT=3001
CREDENTIAL_ENCRYPTION_KEY=replace-with-32-byte-secret
CRAWLER_ADAPTER_NAME=mock
X_BINDING_SESSION_TIMEOUT_SECONDS=600
REAL_CRAWLER_MAX_POSTS=20
# Optional: prefer local Chrome for interactive login
# X_BROWSER_CHANNEL=chrome
# X_BROWSER_EXECUTABLE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
